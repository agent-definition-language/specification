{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adl-spec.org/profiles/governance/1.0/schema.json",
  "title": "ADL Governance Profile",
  "description": "JSON Schema for ADL documents declaring the governance profile (urn:adl:profile:governance:1.0). Extends the base ADL schema via allOf composition.",
  "$defs": {
    "extensions": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*)+$": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false,
      "description": "Vendor-namespaced extensions. Keys are reverse-domain identifiers."
    }
  },
  "allOf": [
    {
      "$ref": "https://adl-spec.org/0.3/schema.json"
    }
  ],
  "type": "object",
  "required": [
    "compliance_framework",
    "autonomy"
  ],
  "properties": {
    "profiles": {
      "type": "array",
      "contains": {
        "const": "urn:adl:profile:governance:1.0"
      }
    },
    "compliance_framework": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "primary_framework"
      ],
      "properties": {
        "primary_framework": {
          "type": "string",
          "enum": [
            "NIST_800_53",
            "SOC2_TYPE_II",
            "ISO_27001",
            "ISO_42001",
            "GDPR",
            "HIPAA",
            "PCI_DSS",
            "EU_AI_ACT",
            "IMDA_AGENTIC",
            "NIST_AI_RMF"
          ]
        },
        "control_mappings": {
          "type": "array",
          "items": {
            "additionalProperties": false,
            "type": "object",
            "required": [
              "framework",
              "control_id",
              "status"
            ],
            "properties": {
              "framework": {
                "type": "string"
              },
              "control_id": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": [
                  "implemented",
                  "partial",
                  "planned",
                  "not_applicable"
                ]
              },
              "extensions": {
                "$ref": "#/$defs/extensions"
              }
            }
          }
        },
        "audit_dates": {
          "additionalProperties": false,
          "type": "object",
          "properties": {
            "last_audit": {
              "format": "date-time",
              "type": "string"
            },
            "next_audit": {
              "format": "date-time",
              "type": "string"
            },
            "extensions": {
              "$ref": "#/$defs/extensions"
            }
          }
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "autonomy": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "tier",
        "basis",
        "classified_by",
        "classified_at"
      ],
      "properties": {
        "tier": {
          "type": "integer",
          "enum": [
            1,
            2,
            3
          ]
        },
        "basis": {
          "minLength": 1,
          "type": "string"
        },
        "classified_by": {
          "minLength": 1,
          "type": "string"
        },
        "classified_at": {
          "format": "date-time",
          "type": "string"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "risk_classification": {
      "additionalProperties": false,
      "type": "object",
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "autonomy_level": {
          "type": "string",
          "enum": [
            "L0",
            "L1",
            "L2",
            "L3",
            "L4",
            "L5"
          ]
        },
        "assessed_by": {
          "type": "string"
        },
        "assessed_at": {
          "format": "date-time",
          "type": "string"
        },
        "rationale": {
          "type": "string"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "human_oversight": {
      "additionalProperties": false,
      "type": "object",
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "none",
            "on_exception",
            "periodic",
            "continuous"
          ]
        },
        "role": {
          "type": "string"
        },
        "triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "required": [
                  "when"
                ],
                "properties": {
                  "description": {
                    "type": "string"
                  },
                  "when": {
                    "type": "object",
                    "minProperties": 1,
                    "properties": {
                      "cost_usd_over": {
                        "type": "number",
                        "exclusiveMinimum": 0
                      },
                      "data_classification_at_least": {
                        "type": "string",
                        "enum": [
                          "public",
                          "internal",
                          "confidential",
                          "restricted"
                        ]
                      },
                      "tool": {
                        "type": "string"
                      },
                      "path_matches": {
                        "type": "string"
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "additionalProperties": false
              }
            ]
          }
        },
        "response_time_minutes": {
          "minimum": 1,
          "type": "integer"
        },
        "intervention_model": {
          "type": "string",
          "enum": [
            "approve_reject",
            "plan_editing",
            "monitor_only"
          ]
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "incident_response": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "policy_documented"
      ],
      "properties": {
        "policy_documented": {
          "type": "boolean"
        },
        "last_tested": {
          "format": "date-time",
          "type": "string"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "evaluation_attestation": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "result",
        "evaluator",
        "evaluation_date"
      ],
      "properties": {
        "result": {
          "type": "string",
          "enum": [
            "passed",
            "conditional",
            "failed"
          ]
        },
        "evaluator": {
          "minLength": 1,
          "type": "string"
        },
        "evaluation_date": {
          "format": "date-time",
          "type": "string"
        },
        "methodology": {
          "type": "string",
          "enum": [
            "automated_benchmark",
            "red_team",
            "third_party_audit",
            "sandbox",
            "internal_review"
          ]
        },
        "expires_at": {
          "format": "date-time",
          "type": "string"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "disclosure": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "required"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "known_limitations": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "prohibited_uses": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "user_responsibilities": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reporting_contact": {
          "format": "uri",
          "type": "string"
        },
        "disclosure_version": {
          "type": "string"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "safety_reviews": {
      "additionalProperties": false,
      "type": "object",
      "properties": {
        "required": {
          "type": "boolean"
        },
        "frequency": {
          "type": "string"
        },
        "last_review": {
          "format": "date-time",
          "type": "string"
        },
        "next_review": {
          "format": "date-time",
          "type": "string"
        },
        "review_board": {
          "type": "string"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "governance": {
      "additionalProperties": false,
      "type": "object",
      "properties": {
        "ownership": {
          "additionalProperties": false,
          "type": "object",
          "properties": {
            "owner": {
              "type": "string"
            },
            "delegate": {
              "type": "string"
            },
            "contact": {
              "format": "email",
              "type": "string"
            },
            "user_escalation_contact": {
              "format": "uri",
              "type": "string"
            },
            "decision_boundaries": {
              "minItems": 1,
              "type": "array",
              "items": {
                "additionalProperties": false,
                "type": "object",
                "required": [
                  "decision_type",
                  "owner"
                ],
                "properties": {
                  "decision_type": {
                    "type": "string"
                  },
                  "owner": {
                    "type": "string",
                    "enum": [
                      "human_only",
                      "agent",
                      "human_in_loop"
                    ]
                  },
                  "rationale": {
                    "type": "string"
                  },
                  "extensions": {
                    "$ref": "#/$defs/extensions"
                  }
                }
              }
            },
            "extensions": {
              "$ref": "#/$defs/extensions"
            }
          }
        },
        "approval_workflow": {
          "additionalProperties": false,
          "type": "object",
          "properties": {
            "required": {
              "type": "boolean"
            },
            "approvers": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "approval_type": {
              "type": "string",
              "enum": [
                "any",
                "all",
                "quorum"
              ]
            },
            "extensions": {
              "$ref": "#/$defs/extensions"
            }
          }
        },
        "audit_trail": {
          "additionalProperties": false,
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "retention_days": {
              "minimum": 0,
              "type": "integer"
            },
            "destination": {
              "format": "uri",
              "type": "string"
            },
            "extensions": {
              "$ref": "#/$defs/extensions"
            }
          }
        },
        "lifecycle_governance": {
          "additionalProperties": false,
          "type": "object",
          "properties": {
            "transition_policy": {
              "additionalProperties": false,
              "type": "object",
              "properties": {
                "requires_approval": {
                  "type": "boolean"
                },
                "approvers": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "approval_type": {
                  "type": "string",
                  "enum": [
                    "any",
                    "all",
                    "quorum"
                  ]
                },
                "notice_period_days": {
                  "minimum": 0,
                  "type": "integer"
                },
                "allowed_transitions": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "extensions": {
                  "$ref": "#/$defs/extensions"
                }
              }
            },
            "last_transition": {
              "additionalProperties": false,
              "type": "object",
              "properties": {
                "from_status": {
                  "type": "string",
                  "enum": [
                    "draft",
                    "active",
                    "deprecated",
                    "retired"
                  ]
                },
                "to_status": {
                  "type": "string",
                  "enum": [
                    "draft",
                    "active",
                    "deprecated",
                    "retired"
                  ]
                },
                "approved_by": {
                  "type": "string"
                },
                "approved_at": {
                  "format": "date-time",
                  "type": "string"
                },
                "reason": {
                  "type": "string"
                },
                "extensions": {
                  "$ref": "#/$defs/extensions"
                }
              }
            },
            "extensions": {
              "$ref": "#/$defs/extensions"
            }
          }
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "governance_record_ref": {
      "format": "uri",
      "type": "string"
    },
    "anomaly_baseline": {
      "additionalProperties": false,
      "type": "object",
      "properties": {
        "expected_tools": {
          "type": "array",
          "items": {
            "additionalProperties": false,
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "share": {
                "minimum": 0,
                "maximum": 1,
                "type": "number"
              }
            }
          }
        },
        "cost_per_session_usd": {
          "additionalProperties": false,
          "type": "object",
          "properties": {
            "min": {
              "minimum": 0,
              "type": "number"
            },
            "max": {
              "minimum": 0,
              "type": "number"
            }
          }
        },
        "data_classes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "pii",
              "phi",
              "financial",
              "credentials",
              "intellectual_property",
              "regulatory"
            ]
          }
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    }
  },
  "if": {
    "properties": {
      "autonomy": {
        "properties": {
          "tier": {
            "enum": [
              2,
              3
            ]
          }
        },
        "required": [
          "tier"
        ]
      }
    },
    "required": [
      "autonomy"
    ]
  },
  "then": {
    "required": [
      "human_oversight",
      "incident_response",
      "disclosure"
    ],
    "properties": {
      "human_oversight": {
        "required": [
          "triggers",
          "response_time_minutes"
        ]
      },
      "incident_response": {
        "properties": {
          "policy_documented": {
            "const": true
          }
        }
      },
      "disclosure": {
        "properties": {
          "required": {
            "const": true
          }
        }
      }
    },
    "if": {
      "properties": {
        "autonomy": {
          "properties": {
            "tier": {
              "const": 3
            }
          }
        }
      }
    },
    "then": {
      "required": [
        "human_oversight",
        "incident_response",
        "disclosure",
        "evaluation_attestation",
        "anomaly_baseline"
      ],
      "properties": {
        "evaluation_attestation": {
          "properties": {
            "result": {
              "const": "passed"
            }
          }
        }
      }
    }
  },
  "$comment": "Open additive mixin: intentionally has no root unevaluatedProperties so this profile composes with others via allOf (spec 13.2). Validators apply unevaluatedProperties:false once over the composed schema (base + all declared profiles), per spec 13.1."
}

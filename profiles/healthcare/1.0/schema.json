{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adl-spec.org/profiles/healthcare/1.0/schema.json",
  "title": "ADL Healthcare Profile",
  "description": "JSON Schema for ADL documents declaring the healthcare profile (urn:adl:profile:healthcare:1.0). Extends the base ADL schema via allOf composition.",
  "$defs": {
    "extensions": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*)+$": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false,
      "description": "Vendor-namespaced extensions. Keys are reverse-domain identifiers."
    }
  },
  "allOf": [
    { "$ref": "https://adl-spec.org/0.3/schema.json" },
    {
      "comment": "HC-11: substance use disorder records (42 CFR Part 2) require consent management.",
      "if": {
        "properties": {
          "data_classification": {
            "properties": {
              "healthcare": {
                "properties": {
                  "phi_types": { "contains": { "const": "substance_use" } }
                },
                "required": ["phi_types"]
              }
            },
            "required": ["healthcare"]
          }
        },
        "required": ["data_classification"]
      },
      "then": {
        "properties": {
          "phi_handling": { "required": ["consent_management"] }
        },
        "required": ["phi_handling"]
      }
    },
    {
      "comment": "HC-14: an FDA device class beyond exempt/non_device requires a documented change control plan.",
      "if": {
        "required": ["clinical_safety"],
        "properties": {
          "clinical_safety": {
            "required": ["fda_classification"],
            "properties": {
              "fda_classification": {
                "required": ["device_class"],
                "properties": {
                  "device_class": {
                    "enum": ["class_I", "class_II", "class_III"]
                  }
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "clinical_safety": { "required": ["change_control"] }
        }
      }
    },
    {
      "comment": "HC-15: a predictive DSI must publish source attributes and document IRM practices (ONC HTI-1).",
      "if": {
        "required": ["interoperability"],
        "properties": {
          "interoperability": {
            "required": ["dsi_transparency"],
            "properties": {
              "dsi_transparency": {
                "required": ["predictive_dsi"],
                "properties": { "predictive_dsi": { "const": true } }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "interoperability": {
            "properties": {
              "dsi_transparency": {
                "required": ["source_attributes_published", "irm_practices"],
                "properties": {
                  "source_attributes_published": { "const": true },
                  "irm_practices": { "const": true }
                }
              }
            }
          }
        }
      }
    }
  ],
  "type": "object",
  "required": ["hipaa_compliance", "phi_handling"],
  "properties": {
    "profiles": {
      "type": "array",
      "contains": { "const": "urn:adl:profile:healthcare:1.0" }
    },
    "data_classification": {
      "type": "object",
      "required": ["healthcare"],
      "properties": {
        "categories": { "contains": { "const": "phi" } },
        "healthcare": {
          "type": "object",
          "required": ["phi_types"],
          "properties": {
            "phi_types": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "demographics",
                  "medical_records",
                  "billing",
                  "mental_health",
                  "substance_use",
                  "genetic",
                  "reproductive",
                  "hiv_status"
                ]
              }
            },
            "hipaa_applicability": { "type": "boolean" },
            "extensions": { "$ref": "#/$defs/extensions" }
          },
          "additionalProperties": false
        }
      }
    },
    "hipaa_compliance": {
      "type": "object",
      "required": ["covered_entity_type", "baa_required", "minimum_necessary"],
      "properties": {
        "covered_entity_type": {
          "type": "string",
          "enum": ["covered_entity", "business_associate", "subcontractor"]
        },
        "baa_required": { "type": "boolean" },
        "minimum_necessary": {
          "type": "object",
          "required": ["scope"],
          "properties": {
            "scope": {
              "type": "string",
              "enum": ["task_specific", "role_based", "full_record"]
            },
            "justification": { "type": "string" },
            "review_frequency": { "type": "string" },
            "extensions": { "$ref": "#/$defs/extensions" }
          },
          "additionalProperties": false
        },
        "security_rule": {
          "type": "object",
          "properties": {
            "encryption_at_rest": {
              "type": "string",
              "enum": ["AES_256", "AES_128"]
            },
            "encryption_in_transit": {
              "type": "string",
              "enum": ["TLS_1_2", "TLS_1_3"]
            },
            "mfa_required": { "type": "boolean" },
            "data_retention": {
              "type": "string",
              "enum": ["none", "minimum", "standard"]
            },
            "restoration_hours": { "type": "number", "minimum": 0 },
            "extensions": { "$ref": "#/$defs/extensions" }
          },
          "additionalProperties": false
        },
        "extensions": { "$ref": "#/$defs/extensions" }
      },
      "additionalProperties": false
    },
    "phi_handling": {
      "type": "object",
      "required": ["de_identification", "breach_notification"],
      "properties": {
        "de_identification": {
          "type": "object",
          "required": ["method"],
          "properties": {
            "method": {
              "type": "string",
              "enum": ["safe_harbor", "expert_determination", "none"]
            },
            "re_identification_controls": { "type": "boolean" },
            "extensions": { "$ref": "#/$defs/extensions" }
          },
          "additionalProperties": false
        },
        "breach_notification": {
          "type": "object",
          "required": ["notification_hours", "contact"],
          "properties": {
            "notification_hours": { "type": "number", "minimum": 0 },
            "contact": { "type": "string" },
            "threshold": { "type": "number", "minimum": 0 },
            "extensions": { "$ref": "#/$defs/extensions" }
          },
          "additionalProperties": false
        },
        "consent_management": {
          "type": "object",
          "properties": {
            "required": { "type": "boolean" },
            "consent_types": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "treatment",
                  "payment",
                  "operations",
                  "research",
                  "marketing"
                ]
              }
            },
            "granularity": {
              "type": "string",
              "enum": ["broad", "purpose_specific", "data_specific"]
            },
            "revocation_supported": { "type": "boolean" },
            "extensions": { "$ref": "#/$defs/extensions" }
          },
          "additionalProperties": false
        },
        "data_provenance": {
          "type": "object",
          "properties": {
            "tracking": { "type": "boolean" },
            "source_systems": {
              "type": "array",
              "items": { "type": "string" }
            },
            "extensions": { "$ref": "#/$defs/extensions" }
          },
          "additionalProperties": false
        },
        "extensions": { "$ref": "#/$defs/extensions" }
      },
      "additionalProperties": false
    },
    "clinical_safety": {
      "type": "object",
      "properties": {
        "fda_classification": {
          "type": "object",
          "properties": {
            "device_class": {
              "type": "string",
              "enum": [
                "exempt",
                "class_I",
                "class_II",
                "class_III",
                "non_device"
              ]
            },
            "clearance_type": {
              "type": "string",
              "enum": ["510k", "de_novo", "pma", "not_applicable"]
            },
            "clearance_number": { "type": "string" },
            "software_level": {
              "type": "string",
              "enum": [
                "non_significant_risk",
                "significant_risk",
                "life_supporting"
              ]
            },
            "extensions": { "$ref": "#/$defs/extensions" }
          },
          "additionalProperties": false
        },
        "change_control": {
          "type": "object",
          "properties": {
            "pccp_authorized": { "type": "boolean" },
            "modification_scope": {
              "type": "array",
              "items": { "type": "string" }
            },
            "validation_protocol": { "type": "string", "format": "uri" },
            "rollback_plan": { "type": "boolean" },
            "monitoring_frequency": { "type": "string" },
            "extensions": { "$ref": "#/$defs/extensions" }
          },
          "additionalProperties": false
        },
        "bias_monitoring": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "protected_classes": {
              "type": "array",
              "items": { "type": "string" }
            },
            "assessment_frequency": { "type": "string" },
            "last_assessment": { "type": "string", "format": "date-time" },
            "extensions": { "$ref": "#/$defs/extensions" }
          },
          "additionalProperties": false
        },
        "human_in_the_loop": {
          "type": "object",
          "properties": {
            "level": {
              "type": "string",
              "enum": ["advisory", "approval_required", "continuous_oversight"]
            },
            "role": { "type": "string" },
            "escalation_path": { "type": "string" },
            "extensions": { "$ref": "#/$defs/extensions" }
          },
          "additionalProperties": false
        },
        "extensions": { "$ref": "#/$defs/extensions" }
      },
      "additionalProperties": false
    },
    "interoperability": {
      "type": "object",
      "properties": {
        "fhir_version": {
          "type": "string",
          "enum": ["DSTU2", "STU3", "R4", "R4B", "R5"]
        },
        "terminology_bindings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tefca_participant": { "type": "boolean" },
        "information_blocking": {
          "type": "object",
          "properties": {
            "compliant": { "type": "boolean" },
            "exceptions_claimed": {
              "type": "array",
              "items": { "type": "string" }
            },
            "extensions": { "$ref": "#/$defs/extensions" }
          },
          "additionalProperties": false
        },
        "dsi_transparency": {
          "type": "object",
          "properties": {
            "predictive_dsi": { "type": "boolean" },
            "source_attributes_published": { "type": "boolean" },
            "irm_practices": { "type": "boolean" },
            "extensions": { "$ref": "#/$defs/extensions" }
          },
          "additionalProperties": false
        },
        "extensions": { "$ref": "#/$defs/extensions" }
      },
      "additionalProperties": false
    }
  },
  "$comment": "Open additive mixin: intentionally has no root unevaluatedProperties so this profile composes with others via allOf (spec 13.2). Validators apply unevaluatedProperties:false once over the composed schema (base + all declared profiles), per spec 13.1."
}

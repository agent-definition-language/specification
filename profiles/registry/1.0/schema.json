{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adl-spec.org/profiles/registry/1.0/schema.json",
  "title": "ADL Registry Profile",
  "description": "JSON Schema for ADL documents declaring the registry profile (urn:adl:profile:registry:1.0). Extends the base ADL schema via allOf composition.",
  "$defs": {
    "extensions": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*)+$": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false,
      "description": "Vendor-namespaced extensions. Keys are reverse-domain identifiers."
    }
  },
  "allOf": [
    {
      "$ref": "https://adl-spec.org/0.3/schema.json"
    }
  ],
  "type": "object",
  "required": [
    "registry"
  ],
  "properties": {
    "profiles": {
      "type": "array",
      "contains": {
        "const": "urn:adl:profile:registry:1.0"
      }
    },
    "registry": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "catalog_id"
      ],
      "properties": {
        "catalog_id": {
          "minLength": 1,
          "type": "string"
        },
        "catalog_classification": {
          "type": "array",
          "items": {
            "additionalProperties": false,
            "type": "object",
            "required": [
              "domain"
            ],
            "properties": {
              "domain": {
                "minLength": 1,
                "type": "string"
              },
              "subdomain": {
                "type": "string"
              },
              "capability": {
                "type": "string"
              },
              "extensions": {
                "$ref": "#/$defs/extensions"
              }
            }
          }
        },
        "visibility": {
          "type": "string",
          "enum": [
            "private",
            "internal",
            "public"
          ]
        },
        "federation": {
          "additionalProperties": false,
          "type": "object",
          "properties": {
            "registries": {
              "type": "array",
              "items": {
                "format": "uri",
                "type": "string"
              }
            },
            "primary": {
              "format": "uri",
              "type": "string"
            },
            "extensions": {
              "$ref": "#/$defs/extensions"
            }
          }
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    }
  },
  "$comment": "Open additive mixin: intentionally has no root unevaluatedProperties so this profile composes with others via allOf (spec 13.2). Validators apply unevaluatedProperties:false once over the composed schema (base + all declared profiles), per spec 13.1."
}

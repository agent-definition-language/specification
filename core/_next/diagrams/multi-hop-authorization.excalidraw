    },
    {
      "type": "text", "id": "wg3", "x": 1896, "y": 746, "width": 624, "height": 20,
      "text": "Presentation proofs claim the minimum.", "originalText": "Presentation proofs claim the minimum.",
      "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#334155", "backgroundColor": "transparent",

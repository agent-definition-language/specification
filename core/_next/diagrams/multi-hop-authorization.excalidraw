    {
      "type": "text", "id": "wg4", "x": 1896, "y": 794, "width": 624, "height": 20,
      "text": "Scopes are reduced to the minimum required at each hop (§10.4.5).", "originalText": "Scopes are reduced to the minimum required at each hop (§10.4.5).",

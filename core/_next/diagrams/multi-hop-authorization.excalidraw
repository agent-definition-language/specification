    {
      "type": "text", "id": "wg1", "x": 1896, "y": 650, "width": 624, "height": 20,
      "text": "Every hop authenticates independently.", "originalText": "Every hop authenticates independently.",
      "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",

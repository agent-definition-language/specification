    {
      "type": "text", "id": "p5_body", "x": 2022, "y": 1056, "width": 470, "height": 240,
      "text": "1   Alice → Assistant     OAuth 2.1 (chan)  S_h (standing)\n2   Asst → Calendar MCP   OAuth 2.1 (exch)  calendar:read\n3   Asst → Discovery      No Auth (public)  — (verify only)\n4   Asst → Flight Agent   Passport + Proof  flights:search\n5   Asst → Flight Agent   Passport + Proof  flights:book, pay\n6   Asst → Hotel Agent    Passport + Proof  hotels:search\n7   Asst → Hotel Agent    Passport + Proof  hotels:book, pay",
      "originalText": "1   Alice → Assistant     OAuth 2.1 (chan)  S_h (standing)\n2   Asst → Calendar MCP   OAuth 2.1 (exch)  calendar:read\n3   Asst → Discovery      No Auth (public)  — (verify only)\n4   Asst → Flight Agent   Passport + Proof  flights:search\n5   Asst → Flight Agent   Passport + Proof  flights:book, pay\n6   Asst → Hotel Agent    Passport + Proof  hotels:search\n7   Asst → Hotel Agent    Passport + Proof  hotels:book, pay",
      "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#334155", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 800013, "version": 1, "versionNonce": 800014, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false,
      "containerId": null, "lineHeight": 1.7

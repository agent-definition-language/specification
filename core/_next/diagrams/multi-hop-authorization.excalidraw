    },
    {
      "type": "text", "id": "wg2", "x": 1896, "y": 698, "width": 624, "height": 20,
      "text": "Counterparty requirements come from its Passport (not guessed).", "originalText": "Counterparty requirements come from its Passport (not guessed).",
      "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#334155", "backgroundColor": "transparent",
